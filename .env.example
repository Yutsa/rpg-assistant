# Local development (default): SQLite file, no Docker required
DATABASE_URL=sqlite:///./data/rpg_assistant.db

# Production / shared dev: PostgreSQL (requires `docker compose up -d`)
# DATABASE_URL=postgresql://rpg:rpg@localhost:5432/rpg_assistant

# Raw PDF extractor: legacy (default) or pymupdf4llm
# RPG_INGEST_EXTRACTOR=pymupdf4llm
