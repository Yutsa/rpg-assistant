# Local development (default): SQLite file, no Docker required
DATABASE_URL=sqlite:///./data/rpg_assistant.db

# Production / shared dev: PostgreSQL (requires `docker compose up -d`)
# DATABASE_URL=postgresql://rpg:rpg@localhost:5432/rpg_assistant

# Real PDF benchmarks (proprietary files — never commit to git)
# Cloud agents: downloaded automatically by .cursor/scripts/cloud-agent-install.sh
RPG_PDF_MOMIE=/workspace/data/pdfs/COF2_10_Mondanites_Et_Momies_web_v1a.pdf
RPG_PDF_FAELYS=/workspace/data/pdfs/COF2_07_Le_Dernier_Faelys_web_v0.pdf

# PDF extraction backend: legacy (default) or docling
# RPG_EXTRACTION_PROVIDER=docling
